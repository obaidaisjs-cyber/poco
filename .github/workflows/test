name: Test Kernel Build

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Clone Kernel Source
        run: |
          git clone --depth 1 -b redwood-s-oss https://github.com/MiCode/Xiaomi_Kernel_OpenSource.git kernel
          git clone --depth 1 -b redwood-s-oss https://github.com/MiCode/kernel_devicetree.git kernel/devicetree
          git clone --depth 1 -b redwood-s-oss https://github.com/MiCode/vendor_qcom_opensource_wlan.git kernel/wlan
          git clone --depth 1 -b redwood-s-oss https://github.com/MiCode/kernel_build.git kernel/build

      - name: Install Toolchain
        run: |
          sudo apt-get update
          sudo apt-get install -y bc bison flex libssl-dev libelf-dev

      - name: Find defconfig
        run: |
          echo "=== كل ملفات defconfig تحت arm64 ==="
          find kernel -path "*arch/arm64/configs*" -iname "*defconfig*"
          echo "=== محتوى مجلد arm64/configs بالكامل ==="
          ls -la kernel/arch/arm64/configs/ 2>/dev/null
          echo "=== محتوى مجلد vendor لو موجود ==="
          ls -la kernel/arch/arm64/configs/vendor/ 2>/dev/null

      - name: Attempt Build
        run: |
          cd kernel
          export ARCH=arm64
          make O=out redwood_defconfig || echo "DEFCONFIG_FAILED"
          make O=out -j$(nproc) 2>&1 | tee build_log.txt || echo "BUILD_FAILED"

      - name: Upload Build Log
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: build-log
          path: kernel/build_log.txt

      - name: Upload Kernel Image (if built)
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-kernel-image
          path: kernel/out/arch/arm64/boot/Image.gz-dtb
          if-no-files-found: ignore
